{
  "configurations": [
    {
      "inheritEnvironments": [
        "msvc_x64"
      ],
      "name": "x64-Debug",
      "includePath": [
        "${env.INCLUDE}",
        "${workspaceRoot}",
        "${workspaceRoot}\\**"
      ],
      "defines": [
        "WIN32",
        "_DEBUG",
        "UNICODE",
        "_UNICODE"
      ],
      "intelliSenseMode": "windows-msvc-x64",
      "compilerSwitches": "/std:c++17 /EHsc",
      "buildRoot": "${workspaceRoot}\\build",
      "outputPath": "${workspaceRoot}\\bin"
    },
    {
      "inheritEnvironments": [
        "msvc_x64"
      ],
      "name": "x64-Release",
      "includePath": [
        "${env.INCLUDE}",
        "${workspaceRoot}",
        "${workspaceRoot}\\**"
      ],
      "defines": [
        "WIN32",
        "NDEBUG",
        "UNICODE",
        "_UNICODE"
      ],
      "intelliSenseMode": "windows-msvc-x64",
      "compilerSwitches": "/std:c++17 /EHsc /O2",
      "buildRoot": "${workspaceRoot}\\build",
      "outputPath": "${workspaceRoot}\\bin"
    }
  ]
}